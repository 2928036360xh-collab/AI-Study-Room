<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/title_bg_settings" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:right="0dp" android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/settings_accent" />
            <corners android:topLeftRadius="16dp" android:bottomLeftRadius="16dp" />
            <size android:width="4dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/card_border" />
            <corners android:radius="16dp" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
